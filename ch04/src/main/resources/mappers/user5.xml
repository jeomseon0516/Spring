<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ch04.dao.User5DAO">
    <!--  id값은 DAO의 메서드명으로 맞춰줌  -->
    <select id="select">
        SELECT * FROM User5 WHERE seq=#{seq};
    </select>

    <select id="selectAll">
        SELECT * FROM User5;
    </select>

    <insert id="insert">
        INSERT INTO User5 SET
            seq=#{seq},
            name=#{name},
            gender=#{gender},
            age=#{age},
            addr=#{addr};
    </insert>

    <update id="update">
        UPDATE User5 SET
            name=#{name},
            gender=#{gender},
            age=#{age},
            addr=#{addr}
        WHERE seq=#{seq};
    </update>

    <delete id="delete">
        DELETE FROM User5 WHERE seq=#{seq};
    </delete>
</mapper>